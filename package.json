{
  "name": "gpt-stt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "next build",
    "start": "next start -p 3010",
    "lint": "next lint",
    "models": "node scripts/list-models.mjs",
    "deploy:cloudrun": "gcloud builds submit --config cloudbuild.yaml && gcloud run services add-iam-policy-binding gpt-stt --region asia-northeast3 --member=allUsers --role=roles/run.invoker --quiet",
    "deploy:firebase": "firebase deploy --only hosting"
  },
  "dependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "next": "latest",
    "openai": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest"
  },
  "devDependencies": {
    "sass": "^1.100.0"
  }
}
