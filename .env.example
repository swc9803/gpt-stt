OPENAI_API_KEY=***
# 선택 사항
# OPENAI_STT_MODEL=gpt-4o-mini-transcribe
# OPENAI_CHAT_MODEL=gpt-4o-mini

# 채팅을 Hermes의 OpenAI Codex OAuth로 호출하고 싶을 때만 켠다.
# 이 모드는 서버에 hermes CLI가 설치되어 있고 `hermes auth add openai-codex` 인증이 끝나 있어야 한다.
# CHAT_PROVIDER=hermes-codex
# HERMES_CODEX_MODEL=gpt-5.5
# HERMES_BIN=hermes
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=alloy
# ENABLE_SERVER_TTS=false
# NEXT_PUBLIC_ENABLE_SERVER_TTS=false
