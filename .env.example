OPENAI_API_KEY=sk-...

# Firebase App Hosting에서는 openai를 사용한다.
CHAT_PROVIDER=openai
OPENAI_CHAT_MODEL=gpt-4.1-mini

# 로컬에서만 이 컴퓨터의 Hermes CLI/Codex 인증으로 처리하고 싶을 때 사용한다.
# CHAT_PROVIDER=hermes-codex
# HERMES_CODEX_MODEL=gpt-5.5
# HERMES_BIN=hermes
# HERMES_CODEX_TIMEOUT_MS=90000
# HERMES_CODEX_MAX_TURNS=3

# iPhone/iPad 등에서 브라우저 음성 인식 대신 서버 전사를 쓰고 싶을 때 켠다.
# OpenAI STT 크레딧이 없으면 false로 두거나 제거한다.
NEXT_PUBLIC_ENABLE_OPENAI_STT_FALLBACK=true
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_api_key
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# ENABLE_SERVER_TTS=false
